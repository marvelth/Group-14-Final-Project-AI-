# Ignore version control systems
.git
.gitignore

# Ignore Python caches, compiled files and metadata
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# Ignore local virtual environments
venv/
.venv/
env/
ENV/

# Ignore IDE settings
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore PDF documents/reports and other static documents that are not needed at runtime
documents/
*.pdf

# Ignore environment files
.env
.env.local
